# Railway Environment Variables Template
# Copy these to each service in Railway Dashboard

# ============================================
# PostgreSQL Database (Auto-generated by Railway)
# ============================================
# These are automatically available as ${{Postgres.VARIABLE_NAME}}
# DATABASE_URL=postgresql://user:password@host:port/database
# PGHOST=host
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=railway

# ============================================
# Redis (Auto-generated by Railway)
# ============================================
# These are automatically available as ${{Redis.VARIABLE_NAME}}
# REDIS_URL=redis://default:password@host:port

# ============================================
# Auth Service Environment Variables
# ============================================
PORT=8081
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
RUST_LOG=info

# ============================================
# Metadata Service Environment Variables
# ============================================
PORT=8082
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
RUST_LOG=info

# ============================================
# Storage Node Environment Variables
# ============================================
PORT=8083
STORAGE_DIR=/data
RUST_LOG=info

# ============================================
# Sync Service Environment Variables
# ============================================
PORT=8084
REDIS_URL=${{Redis.REDIS_URL}}
RUST_LOG=info

# ============================================
# Gateway Service Environment Variables
# ============================================
PORT=8080
AUTH_SERVICE_URL=http://auth-service.railway.internal:8081
METADATA_SERVICE_URL=http://metadata-service.railway.internal:8082
STORAGE_SERVICE_URL=http://storage-node.railway.internal:8083
SYNC_SERVICE_URL=http://sync-service.railway.internal:8084
RUST_LOG=info

# CORS Configuration (add your Vercel domain)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ============================================
# Build Arguments (Set in Railway Service Settings)
# ============================================
# For each service, set this in Railway:
# SERVICE=auth-service (or metadata-service, storage-node, etc.)
